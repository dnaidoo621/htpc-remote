#!/bin/bash
set -e

APP_DIR=/opt/htpc-remote
VENV="$APP_DIR/venv"

echo "=== htpc-remote: post-install ==="

# ── 1. Python virtualenv ──────────────────────────────────────────────────────
echo "[1/5] Creating Python virtualenv…"
# --system-site-packages lets pynput find Xlib, gi find GTK
python3 -m venv --system-site-packages "$VENV"
"$VENV/bin/pip" install -q --upgrade pip
"$VENV/bin/pip" install -q -r "$APP_DIR/requirements.txt"

# ── 2. Detect the console / graphical user ────────────────────────────────────
# Try several methods in order of reliability.
REAL_USER=""
# Method 1: who on :0
REAL_USER=$(who 2>/dev/null | awk '/:0/{print $1; exit}')
# Method 2: logind seat
if [ -z "$REAL_USER" ]; then
    REAL_USER=$(loginctl list-sessions --no-legend 2>/dev/null \
        | awk '{print $3; exit}')
fi
# Method 3: first entry in /home
if [ -z "$REAL_USER" ]; then
    REAL_USER=$(ls /home 2>/dev/null | head -1)
fi

echo "  Detected user: ${REAL_USER:-unknown}"

# ── 3. Input group + uinput rule (Wayland support) ───────────────────────────
echo "[2/5] Configuring /dev/uinput permissions…"
if [ -n "$REAL_USER" ] && ! groups "$REAL_USER" 2>/dev/null | grep -q '\binput\b'; then
    usermod -a -G input "$REAL_USER"
    echo "  → Added $REAL_USER to 'input' group"
fi

UDEV_RULE=/etc/udev/rules.d/99-htpc-remote.rules
echo 'KERNEL=="uinput", GROUP="input", MODE="0660", OPTIONS+="static_node=uinput"' \
    > "$UDEV_RULE"
udevadm control --reload-rules 2>/dev/null || true
udevadm trigger            2>/dev/null || true

# ── 4. Enable systemd user service for all users (global) ────────────────────
echo "[3/5] Enabling systemd user service globally…"
# This creates the symlink in /etc/systemd/user/default.target.wants/
# so every user's session will start htpc-remote automatically.
systemctl --user --global enable htpc-remote.service 2>/dev/null || true

# ── 5. Start the service now if the user is already logged in ─────────────────
echo "[4/5] Starting service for current session (if applicable)…"
if [ -n "$REAL_USER" ]; then
    USER_UID=$(id -u "$REAL_USER" 2>/dev/null || true)
    if [ -n "$USER_UID" ] && [ -d "/run/user/$USER_UID" ]; then
        su -l "$REAL_USER" -c \
            "XDG_RUNTIME_DIR=/run/user/$USER_UID systemctl --user daemon-reload && \
             XDG_RUNTIME_DIR=/run/user/$USER_UID systemctl --user restart htpc-remote.service" \
            2>/dev/null || true
    fi
fi

echo "[5/5] Done."
echo ""
echo "  Glide HTPC Remote is installed."
echo "  On next login (or right now) a QR popup will appear on screen."
echo "  Scan it with your phone to start controlling."
echo ""
echo "  Logs:   journalctl --user -u htpc-remote -f"
echo "  Status: systemctl --user status htpc-remote"
